// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id         String   @id @default(uuid())
  name       String
  stripe_id  String?  @unique
  created_at DateTime @default(now())

  customers     Customer[]
  events        Event[]
  mrr_snapshots MRRSnapshot[]
  churn_events  ChurnEvent[]
  health_scores HealthScore[]
  admins        AdminUser[]
}

model AdminUser {
  id            String   @id @default(uuid())
  company_id    String
  company       Company  @relation(fields: [company_id], references: [id])
  email         String
  password_hash String
  mfa_secret    String? // TOTP secret (null until enrolled)
  mfa_enabled   Boolean  @default(false)
  created_at    DateTime @default(now())

  @@unique([company_id, email])
  @@index([email])
}

model Customer {
  id            String    @id @default(uuid())
  company_id    String
  company       Company   @relation(fields: [company_id], references: [id])
  external_id   String?   @unique // e.g., Stripe customer_id
  email         String
  name          String
  plan          String
  status        String // 'active' | 'past_due' | 'canceled' | 'trialing'
  mrr_cents     Int       @default(0)
  billing_cycle String // 'monthly' | 'yearly'
  trial_ends_at DateTime?
  created_at    DateTime  @default(now())

  subscriptions Subscription[]
  events        Event[]
  health_scores HealthScore[]
  churn_events  ChurnEvent[]

  @@index([company_id])
  @@index([status])
}

model Subscription {
  id                     String    @id @default(uuid())
  customer_id            String
  customer               Customer  @relation(fields: [customer_id], references: [id])
  stripe_subscription_id String?   @unique
  plan                   String
  mrr_cents              Int
  status                 String
  current_period_start   DateTime
  current_period_end     DateTime
  canceled_at            DateTime?
  created_at             DateTime  @default(now())

  @@index([customer_id])
  @@index([status])
}

model Event {
  id          String    @id @default(uuid())
  company_id  String
  company     Company   @relation(fields: [company_id], references: [id])
  customer_id String?
  customer    Customer? @relation(fields: [customer_id], references: [id])
  name        String
  properties  Json      @default("{}")
  occurred_at DateTime  @default(now())

  @@index([company_id, occurred_at(sort: Desc)])
  @@index([customer_id])
}

model MRRSnapshot {
  id                    String   @id @default(uuid())
  company_id            String
  company               Company  @relation(fields: [company_id], references: [id])
  date                  DateTime @unique
  mrr_cents             Int
  new_mrr_cents         Int      @default(0)
  expansion_mrr_cents   Int      @default(0)
  contraction_mrr_cents Int      @default(0)
  churned_mrr_cents     Int      @default(0)
  customer_count        Int      @default(0)

  @@index([company_id, date])
}

model HealthScore {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id])
  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id])
  score       Int
  signals     Json
  computed_at DateTime @default(now())

  @@unique([company_id, customer_id, computed_at])
  @@index([company_id])
  @@index([score])
}

model ChurnEvent {
  id             String   @id @default(uuid())
  company_id     String
  company        Company  @relation(fields: [company_id], references: [id])
  customer_id    String
  customer       Customer @relation(fields: [customer_id], references: [id])
  mrr_lost_cents Int
  reason         String
  churned_at     DateTime @default(now())

  @@index([company_id])
  @@index([reason])
}
